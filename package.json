{
  "name": "toxinmap-com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "next typegen && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed:sources": "node scripts/local/run-ts.mjs scripts/db/seed-source-registry.ts",
    "db:status": "node scripts/local/run-ts.mjs scripts/db/check-db.ts",
    "db:validate:idempotence": "python scripts/db/validate_loader_idempotence.py",
    "db:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db/doctor.ps1",
    "db:install:postgres": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db/install-postgres.ps1",
    "db:bootstrap:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db/bootstrap-portable.ps1",
    "db:adopt:postgis": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db/adopt-postgis.ps1",
    "db:load:transformed": "python -u scripts/db/load-transformed-rows.py",
    "db:load:us-mvp": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db/load-us-mvp.ps1",
    "db:load:national": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db/load-national.ps1",
    "etl:demo": "python etl/pipelines/build_demo_layers.py",
    "etl:tri": "python scripts/etl/ingest_tri.py",
    "etl:frs": "python scripts/etl/ingest_frs.py",
    "etl:echo": "python scripts/etl/ingest_echo.py",
    "etl:atsdr-pfas": "python scripts/etl/ingest_atsdr_pfas.py",
    "etl:usgs-pfas": "python scripts/etl/ingest_usgs_pfas.py",
    "etl:npdes-wastewater": "python scripts/etl/ingest_npdes_wastewater.py",
    "etl:usgs-pharma": "python scripts/etl/ingest_usgs_pharma.py",
    "etl:validate-fixtures": "python scripts/etl/validate_fixture_rows.py",
    "data:validate": "node scripts/local/run-ts.mjs scripts/qa/validate-data.ts",
    "qa:validate-live-api": "node scripts/local/run-ts.mjs scripts/qa/validate-live-api.ts",
    "qa:validate-search-ranking": "node scripts/local/run-ts.mjs scripts/qa/validate-search-ranking.ts",
    "qa:validate-selection-priority": "node scripts/local/run-ts.mjs scripts/qa/validate-selection-priority.ts",
    "qa:validate-detail-summary": "node scripts/local/run-ts.mjs scripts/qa/validate-detail-summary.ts",
    "qa:validate-density-legibility": "node scripts/local/run-ts.mjs scripts/qa/validate-density-legibility.ts",
    "qa:validate-zoom-drilldown": "node scripts/local/run-ts.mjs scripts/qa/validate-zoom-drilldown.ts",
    "qa:validate-zoom-detail-contract": "node scripts/local/run-ts.mjs scripts/qa/validate-zoom-detail-contract.ts",
    "qa:validate-local-marker-rendering": "node scripts/local/run-ts.mjs scripts/qa/validate-local-marker-rendering.ts",
    "qa:validate-live-label-quality": "node scripts/local/run-ts.mjs scripts/qa/validate-live-label-quality.ts",
    "qa:validate-selected-state-contract": "node scripts/local/run-ts.mjs scripts/qa/validate-selected-state-contract.ts",
    "qa:validate-selection-context-contract": "node scripts/local/run-ts.mjs scripts/qa/validate-selection-context-contract.ts",
    "qa:validate-local-density-contract": "node scripts/local/run-ts.mjs scripts/qa/validate-local-density-contract.ts",
    "qa:validate-local-focus-priority": "node scripts/local/run-ts.mjs scripts/qa/validate-local-focus-priority.ts",
    "qa:validate-local-spatial-relevance": "node scripts/local/run-ts.mjs scripts/qa/validate-local-spatial-relevance.ts",
    "qa:validate-dense-click-selection": "node scripts/local/run-ts.mjs scripts/qa/validate-dense-click-selection.ts",
    "qa:validate-interaction-contract": "node scripts/local/run-ts.mjs scripts/qa/validate-interaction-contract.ts",
    "qa:validate-browser-interactions": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/validate-browser-interactions.ps1",
    "qa:validate-home-atlas-cache": "node scripts/local/run-ts.mjs scripts/qa/validate-home-atlas-cache.ts",
    "qa:validate-pfas-coverage-notes": "node scripts/local/run-ts.mjs scripts/qa/validate-pfas-coverage-notes.ts",
    "qa:validate-entity-cache-refresh": "node scripts/local/run-ts.mjs scripts/qa/validate-entity-cache-refresh.ts",
    "qa:smoke": "node scripts/local/run-ts.mjs scripts/qa/smoke.ts",
    "local:seed:home-atlas": "node scripts/local/run-ts.mjs scripts/local/seed-home-atlas-cache.ts",
    "local:up": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/up.ps1 -AllowDegradedWithoutDb",
    "local:down": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/down.ps1",
    "local:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/status.ps1",
    "local:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local/verify.ps1"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.97.0",
    "@types/three": "^0.183.1",
    "cesium": "^1.140.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.542.0",
    "next": "^16.2.3",
    "postgres": "^3.4.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-globe.gl": "^2.37.1",
    "resium": "^1.20.1",
    "tailwind-merge": "^3.3.1",
    "three": "^0.183.2",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "copy-webpack-plugin": "^13.0.1",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.37.0",
    "eslint-config-next": "^16.2.3",
    "playwright": "^1.59.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
