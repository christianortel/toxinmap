# Public site URL used by Next.js metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Cesium Ion token for terrain and related services
NEXT_PUBLIC_CESIUM_ACCESS_TOKEN=

# Cesium static asset base path
NEXT_PUBLIC_CESIUM_BASE_URL=/cesium

# Enable only when a valid Cesium token is present
NEXT_PUBLIC_ENABLE_CESIUM_TERRAIN=false

# Local PostGIS database URL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/toxinmap

# Disable automatic source-registry bootstrap if your database should remain read-only
DOWNSTREAM_DISABLE_DB_BOOTSTRAP=false

# Optional base URL override for the smoke script
SMOKE_BASE_URL=http://localhost:3000
